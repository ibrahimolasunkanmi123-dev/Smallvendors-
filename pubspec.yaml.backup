name: smallvendors
description: "Small Vendors Catalog App - Digital catalog for small businesses"
publish_to: 'none'
version: 0.1.0

environment:
  sdk: ^3.9.2

dependencies:
  flutter:
    sdk: flutter
  image_picker: ^1.0.4
  shared_preferences: ^2.2.2
  url_launcher: ^6.2.1
  qr_flutter: ^4.1.0
  uuid: ^4.0.0
  intl: ^0.19.0
  fl_chart: ^0.68.0
  file_picker: ^8.0.0
  csv: ^6.0.0
  path_provider: ^2.1.0
  permission_handler: ^11.0.1
  share_plus: ^7.2.1
  flutter_local_notifications: ^16.3.0
  package_info_plus: ^5.0.1
  provider: ^6.1.1

dev_dependencies:
  flutter_test:
    sdk: flutter
  flutter_lints: ^5.0.0

flutter:
  uses-material-design: true
